[Unit]
Description=Shared Reel Bot nudge scheduler
After=network-online.target reelbot-worker.service
Wants=network-online.target

[Service]
Type=simple
User=reelbot
Group=reelbot
WorkingDirectory=/opt/reelbot
EnvironmentFile=/opt/reelbot/.env
ExecStart=/opt/reelbot/.venv/bin/python worker/scheduler.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
